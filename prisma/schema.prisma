generator client {
  provider      = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Block {
  id        Int      @id @default(autoincrement())
  type      String
  data      Json
  order     Int?
  startAt   DateTime?
  endAt     DateTime?
  locale    String   @default("es")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
}

model PromoBanner {
  id        Int      @id @default(autoincrement())
  image     String
  alt       String
  link      String?
  locale    String
  startAt   DateTime?
  endAt     DateTime?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
}

model HeroSlide {
  id          Int      @id @default(autoincrement())
  image       String
  title       String
  highlight   String?
  description String?
  link        String?
  locale      String
  startAt     DateTime?
  endAt       DateTime?
  isActive    Boolean  @default(true)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
}

enum CategoryType {
  BLOG
  DOCTOR
}

model Category {
  id    String  @id @default(cuid())
  name  String
  slug  String  @unique 
  type      CategoryType @default(DOCTOR)

  parentId String?

  parent   Category?  @relation("CategoryToSub", fields: [parentId], references: [id])
  children Category[] @relation("CategoryToSub")

  blogs    Blog[]
  doctors  DoctorCategory[]

  createdAt DateTime @default(now())

  @@unique([slug, type])
  @@index([parentId])
}

model Blog {
  id          Int   @id @default(autoincrement())
  title       String
  slug        String   @unique
  excerpt     String
  content     String   @db.Text
  image       String
  featured    Boolean  @default(false)
  views       Int      @default(0)
  published   Boolean  @default(true)
  locale    String   @default("es")
  isActive  Boolean  @default(true) 
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id])

  @@index([slug])
  @@index([views])
  @@index([createdAt])
}

model Doctor {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  email       String?
  phone       String?
  image       String?
  description String?  @db.Text

  city        String?
  state       String?

  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  categories  DoctorCategory[]
  places      DoctorPlace[]
  contactRequests ContactRequest[]
}

model DoctorCategory {
  doctorId   String
  categoryId String

  doctor     Doctor   @relation(fields: [doctorId], references: [id])
  category   Category @relation(fields: [categoryId], references: [id])

  @@id([doctorId, categoryId])
}

model DoctorPlace {
  doctorId String
  placeId  String

  doctor Doctor @relation(fields: [doctorId], references: [id])
  place  Place  @relation(fields: [placeId], references: [id])

  @@id([doctorId, placeId])
}

model ContactRequest {
  id        Int      @id @default(autoincrement())
  name      String
  email     String
  phone     String?
  message   String

  doctorId  String?
  doctor    Doctor?  @relation(fields: [doctorId], references: [id])

  createdAt DateTime @default(now())
}

model User {
  id       Int    @id @default(autoincrement())
  email    String @unique
  password String
  role     Role   @default(USER)

  resetToken   String?
  resetExpires DateTime?
}

enum Role {
  ADMIN
  USER
}

enum PlaceType {
  HOSPITAL
  CLINIC
  LAB
  DENTAL
}

model Place {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  type        PlaceType
  
  description String?
  city        String?
  state       String?
  address     String?
  phone       String?
  image       String?

  images      PlaceImage[]

  doctors DoctorPlace[]
  
  createdAt   DateTime @default(now())
}

model PlaceImage {
  id      Int    @id @default(autoincrement())
  url     String
  placeId String

  place   Place @relation(fields: [placeId], references: [id])
}

